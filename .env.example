# NVIDIA NIM API key from https://build.nvidia.com (starts with nvapi-)
NVIDIA_API_KEY=nvapi-your-key-here

# OpenAI-compatible NIM endpoint (default shown)
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model overrides — catalog names change, check https://build.nvidia.com/models
NIM_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl
NIM_TEXT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
NIM_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
